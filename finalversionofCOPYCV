    {
      "cell_type": "code",
      "source": [
        "class GridDetectionModel(nn.Module):\n",
        "    def __init__(self, grid_size=7, dropout_rate=0.3):  # NEW parameter\n",
        "        super().__init__()\n",
        "        self.grid_size = grid_size\n",
        "\n",
        "        self.features = nn.Sequential(\n",
        "            nn.Conv2d(3, 16, 3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(16, 32, 3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(32, 64, 3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Conv2d(64, 128, 3, padding=1), nn.ReLU(), nn.MaxPool2d(2),\n",
        "            nn.Dropout2d(dropout_rate),  # ✅ ADD THIS\n",
        "        )\n",
        "\n",
        "        self.fc = nn.Sequential(\n",
        "            nn.Linear(128 * 14 * 14, 1024),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(dropout_rate),  # ✅ ADD THIS\n",
        "        )\n",
        "        self.output = nn.Linear(1024, grid_size * grid_size * 5)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.features(x)\n",
        "        x = x.view(x.size(0), -1)\n",
        "        x = self.fc(x)  # Now using Sequential\n",
        "        x = self.output(x)\n",
        "        x = x.view(-1, self.grid_size, self.grid_size, 5)\n",
        "\n",
        "        x[..., 0] = torch.sigmoid(x[..., 0])\n",
        "        x[..., 1:] = torch.sigmoid(x[..., 1:])\n",
        "        return x\n",
        "\n",
        "# Put this RIGHT AFTER your imports, before creating the model:\n",
        "\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "print(f\"Using device: {device}\")\n",
        "\n",
        "# THEN create your model:\n",
        "model = GridDetectionModel(dropout_rate=0.3).to(device)"
      ],
