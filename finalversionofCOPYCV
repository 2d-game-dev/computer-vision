        "def detection_loss(pred, target):\n",
        "    obj_mask = target[..., 0] > 0\n",
        "\n",
        "    loss_conf = ((pred[..., 0] - target[..., 0]) ** 2).mean()\n",
        "\n",
        "    if obj_mask.sum() > 0:\n",
        "        loss_bbox = ((pred[obj_mask][..., 1:] - target[obj_mask][..., 1:]) ** 2).mean()\n",
        "    else:\n",
        "        loss_bbox = 0\n",
        "\n",
        "    return loss_conf + loss_bbox\n"
      ],
